# AI semantic analysis is optional. Rule-based diagnosis works without these settings.
# The current automatic AI analysis flow in src/advanced/ollama_analyzer.py uses local Ollama.
ENABLE_AI_ANALYSIS=false
MODEL_PROVIDER=ollama
MODEL_NAME=qwen3:8b
OLLAMA_BASE_URL=http://localhost:11434
AI_MAX_ITEMS=1

# Rule thresholds used by the advanced command-line entry.
MAX_DEPTH=8
MAX_CHILDREN=2000

# The configuration object can read these API keys, but the current automatic
# analyzer does not implement online OpenAI or Google calls.
OPENAI_API_KEY=
GOOGLE_API_KEY=
